{
  "general": {
    "name": "sample_sim",
    "input_folder": "./examples/",
    "output_folder": "./output/",
    "database": "sample_sim.db",
    "update_paths": {
      "interval": 300,
      "throw_on_empty": false
    },
    "save_data": {
      "interval": 300,
      "avg": true,
      "road": true,
      "travel": false,
      "agent": false
    }
  },
  "road_network": {
    "edges_file": "edges.csv",
    "node_properties_file": "node_props.csv",
    "set_edge_weight": {
      "weight": "traveltime",
      "threshold": 0.05
    }
  },
  "dynamics": {
    "error_probability": 0.05,
    "kill_stagnant_agents": 40.0,
    "agent_insertion_method": "RANDOM",
  }
}
